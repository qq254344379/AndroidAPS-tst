<?xml version="1.0" encoding="utf-8"?>
<!-- Monochrome variant of ic_bg_graph (BG graph menu icon) for the BG graph complication:
     complication provider icons must be plain tintable white so pickers (e.g. Samsung Wearable
     app) can render them; glyph scaled to match the other complication icons -->
