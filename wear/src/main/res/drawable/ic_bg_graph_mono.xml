        android:fillColor="@android:color/white"
        android:pathData="M2,15 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M4,13 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M6,10 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M8,6 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M10,5 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M12,8 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M14.5,12 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M17,16 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M19.5,19 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0M22,20 m-1.3,0 a1.3,1.3 0,1 1,2.6,0 a1.3,1.3 0,1 1,-2.6,0" />
